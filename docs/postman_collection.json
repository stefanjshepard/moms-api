{
  "info": {
    "name": "Moms Website API",
    "_postman_id": "9f0b3b6c-df95-4ccd-92de-04ef451b3d72",
    "description": "Postman collection for Moms Website API. Set collection variables first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api" },
    { "key": "adminKey", "value": "your-admin-key" },
    { "key": "serviceId", "value": "" },
    { "key": "appointmentId", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "blogPostId", "value": "" },
    { "key": "testimonialId", "value": "" },
    { "key": "contactId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "ownerKey", "value": "global" },
    { "key": "paymentConfirmationSecret", "value": "" },
    { "key": "intuitWebhookSecret", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          }
        }
      ]
    },
    {
      "name": "Public - Services",
      "item": [
        {
          "name": "GET /services",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/services", "host": ["{{baseUrl}}"], "path": ["services"] }
          }
        },
        {
          "name": "GET /services/:id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/services/{{serviceId}}", "host": ["{{baseUrl}}"], "path": ["services", "{{serviceId}}"] }
          }
        }
      ]
    },
    {
      "name": "Public - Appointments",
      "item": [
        {
          "name": "POST /appointments",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientFirstName\": \"John\",\n  \"clientLastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+15555551234\",\n  \"date\": \"2026-05-20T17:00:00.000Z\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"paymentMethod\": \"credit_card\",\n  \"paymentStatus\": \"pending\",\n  \"tipAmount\": 0\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments", "host": ["{{baseUrl}}"], "path": ["appointments"] }
          }
        },
        {
          "name": "GET /appointments",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/appointments", "host": ["{{baseUrl}}"], "path": ["appointments"] }
          }
        },
        {
          "name": "GET /appointments with filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/appointments?serviceId={{serviceId}}&dateFrom=2026-05-20T00:00:00.000Z&dateTo=2026-05-21T00:00:00.000Z",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"],
              "query": [
                { "key": "serviceId", "value": "{{serviceId}}" },
                { "key": "dateFrom", "value": "2026-05-20T00:00:00.000Z" },
                { "key": "dateTo", "value": "2026-05-21T00:00:00.000Z" }
              ]
            }
          }
        },
        {
          "name": "GET /appointments/available",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/appointments/available?serviceId={{serviceId}}&date=2026-05-20",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "available"],
              "query": [
                { "key": "serviceId", "value": "{{serviceId}}" },
                { "key": "date", "value": "2026-05-20" }
              ]
            }
          }
        },
        {
          "name": "GET /appointments/:id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/appointments/{{appointmentId}}", "host": ["{{baseUrl}}"], "path": ["appointments", "{{appointmentId}}"] }
          }
        },
        {
          "name": "PUT /appointments/:id",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-05-21T17:00:00.000Z\",\n  \"paymentMethod\": \"venmo\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments/{{appointmentId}}", "host": ["{{baseUrl}}"], "path": ["appointments", "{{appointmentId}}"] }
          }
        },
        {
          "name": "PUT /appointments/:id/confirm",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-payment-confirmation-secret", "value": "{{paymentConfirmationSecret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\",\n  \"paymentStatus\": \"completed\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments/{{appointmentId}}/confirm", "host": ["{{baseUrl}}"], "path": ["appointments", "{{appointmentId}}", "confirm"] }
          }
        },
        {
          "name": "DELETE /appointments/:id",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/appointments/{{appointmentId}}", "host": ["{{baseUrl}}"], "path": ["appointments", "{{appointmentId}}"] }
          }
        }
      ]
    },
